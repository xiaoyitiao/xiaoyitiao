# 智药伴后端环境配置示例
# 复制此文件为 .env 并根据实际情况修改
# 所有配置项均可通过环境变量覆盖

# ==================== 服务器配置 ====================
SERVER_PORT=8080

# ==================== 数据库配置（必填）====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=zhiyaoban
MYSQL_USER=root
MYSQL_PASSWORD=root

# ==================== JWT 配置（必填）====================
# 生产环境必须设置强密钥，建议32位以上随机字符串
JWT_SECRET=zhiyaoban-default-secret-must-be-replaced-in-production
JWT_EXPIRATION=86400000

# ==================== 短信服务配置 ====================
# 是否启用模拟模式（true=使用固定验证码123456，不发送真实短信）
SMS_MOCK=true

# 阿里云短信配置（当 SMS_MOCK=false 时必填）
SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
SMS_SIGN_NAME=智药伴
SMS_TEMPLATE_CODE=SMS_123456789

# ==================== 推送服务配置 ====================
# 推送平台：mock（模拟）/ jpush（极光）/ webpush（Web Push）
PUSH_PLATFORM=mock

# 极光推送配置（当 PUSH_PLATFORM=jpush 时必填）
JPUSH_APP_KEY=your-jpush-app-key
JPUSH_MASTER_SECRET=your-jpush-master-secret
JPUSH_PRODUCTION=false

# Web Push 配置（当 PUSH_PLATFORM=webpush 时必填）
PUSH_VAPID_PUBLIC_KEY=your-vapid-public-key
PUSH_VAPID_PRIVATE_KEY=your-vapid-private-key

# ==================== AI 服务配置（可选）====================
AI_ENABLED=false
AI_API_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key
AI_MODEL=gpt-4

# ==================== 其他配置 ====================
# 日志级别
LOG_LEVEL=INFO

# 允许的 CORS 来源
# ⚠️ 安全警告：生产环境必须使用具体域名，严禁使用 *
# 示例：CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
# 开发环境可使用：CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_ORIGIN=http://localhost:5173
