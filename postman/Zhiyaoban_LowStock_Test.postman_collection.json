{
	"info": {
		"name": "智药伴-库存不足提醒测试",
		"description": "用于测试库存不足提醒功能的Postman脚本",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. 发送验证码",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('发送验证码成功', function() {",
							"    pm.response.to.have.status(200);",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"phone\": \"13800001001\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/auth/send-code",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "send-code"]
				}
			}
		},
		{
			"name": "2. 登录获取Token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.collectionVariables.set('token', jsonData.data.token);",
							"pm.collectionVariables.set('userId', jsonData.data.userId);",
							"",
							"pm.test('登录成功并获取Token', function() {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(jsonData.data.token).to.not.be.empty;",
							"});",
							"",
							"console.log('Token: ' + jsonData.data.token);"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"phone\": \"13800001001\",\n    \"code\": \"123456\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "login"]
				}
			}
		},
		{
			"name": "3. 创建药品（库存不足）",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.collectionVariables.set('medicineId', jsonData.data.id);",
							"",
							"pm.test('药品创建成功', function() {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(jsonData.data.id).to.be.a('number');",
							"    pm.expect(jsonData.data.stock).to.equal(3);",
							"});",
							"",
							"console.log('Medicine ID: ' + jsonData.data.id);"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"阿司匹林肠溶片\",\n    \"dose\": \"100mg\",\n    \"time\": \"08:00\",\n    \"frequency\": \"DAILY\",\n    \"stock\": 3,\n    \"icon\": \"💊\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/medicines",
					"host": ["{{baseUrl}}"],
					"path": ["medicines"]
				}
			}
		},
		{
			"name": "4. 创建库存提醒计划",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.collectionVariables.set('scheduleId', jsonData.data.id);",
							"",
							"pm.test('提醒计划创建成功', function() {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(jsonData.data.id).to.be.a('number');",
							"    pm.expect(jsonData.data.type).to.equal('STOCK');",
							"});",
							"",
							"console.log('Schedule ID: ' + jsonData.data.id);"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"库存不足提醒\",\n    \"type\": \"STOCK\",\n    \"enabled\": true,\n    \"channel\": \"PUSH\",\n    \"advanceMinutes\": 0,\n    \"repeatCount\": 1,\n    \"repeatIntervalMinutes\": 30,\n    \"medicineItems\": [\n        {\n            \"medicineId\": {{medicineId}},\n            \"remindTime\": \"09:00\",\n            \"dose\": \"100mg\",\n            \"enabled\": true\n        }\n    ]\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/reminders/schedules",
					"host": ["{{baseUrl}}"],
					"path": ["reminders", "schedules"]
				}
			}
		},
		{
			"name": "5. 触发库存检查",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('触发成功', function() {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"console.log('Reminder triggered. Check reminder_logs table for results.');"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/reminders/schedules/{{scheduleId}}/trigger?medicineId={{medicineId}}",
					"host": ["{{baseUrl}}"],
					"path": ["reminders", "schedules", "{{scheduleId}}", "trigger"],
					"query": [
						{
							"key": "medicineId",
							"value": "{{medicineId}}"
						}
					]
				}
			}
		},
		{
			"name": "6. 查询提醒日志",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"",
							"pm.test('查询成功', function() {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"if (jsonData.data && jsonData.data.length > 0) {",
							"    console.log('Found ' + jsonData.data.length + ' reminder logs');",
							"    jsonData.data.forEach(function(log) {",
							"        console.log('Type: ' + log.type + ', Status: ' + log.status + ', Content: ' + log.content);",
							"    });",
							"} else {",
							"    console.log('No reminder logs found');",
							"}"
						]
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/reminders/logs?userId={{userId}}",
					"host": ["{{baseUrl}}"],
					"path": ["reminders", "logs"],
					"query": [
						{
							"key": "userId",
							"value": "{{userId}}"
						}
					]
				}
			}
		},
		{
			"name": "7. 查询用户统计",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"",
							"pm.test('查询成功', function() {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"console.log('Statistics:', JSON.stringify(jsonData.data, null, 2));"
						]
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/user/statistics",
					"host": ["{{baseUrl}}"],
					"path": ["user", "statistics"]
				}
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080/api"
		},
		{
			"key": "token",
			"value": ""
		},
		{
			"key": "userId",
			"value": ""
		},
		{
			"key": "medicineId",
			"value": ""
		},
		{
			"key": "scheduleId",
			"value": ""
		}
	]
}
